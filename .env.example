# ── Backend API ───────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Use the shared postgres-server container in production:
DATABASE_URL=postgres://wordcore:your_db_password@postgres-server:5432/wordcore?sslmode=disable

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# OpenRouter API key — get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use for sentence checking (default shown below)
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── Local development only ────────────────────────────────────────────────────
# In production, frontend and API share the same origin — no env var needed.
# For local dev, create .env.local and set:
# VITE_API_BASE_URL=http://localhost:8080

# ── Word generation script (offline, not needed for the app) ─────────────────
GEMINI_API_KEY=your_gemini_key_here
